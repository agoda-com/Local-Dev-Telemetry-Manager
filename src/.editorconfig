[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

# Sonar Way Rules for C#
[*.cs]
# Code Smells (Maintainability)
dotnet_diagnostic.S100.severity = warning  # Method names should comply with a naming convention
dotnet_diagnostic.S101.severity = warning  # Class names should comply with a naming convention
dotnet_diagnostic.S104.severity = warning  # Files should not have too many lines of code
dotnet_diagnostic.S1066.severity = warning # Eliminate nested blocks of code
dotnet_diagnostic.S107.severity = warning  # Methods should not have too many parameters
dotnet_diagnostic.S110.severity = warning  # Avoid too many methods in a class
dotnet_diagnostic.S1125.severity = suggestion # Remove the unnecessary boolean literal
dotnet_diagnostic.S1135.severity = suggestion # Track TODO comments
dotnet_diagnostic.S1134.severity = suggestion # Track FIXME comments
dotnet_diagnostic.S1142.severity = warning # Methods should not have too many return statements
dotnet_diagnostic.S1144.severity = warning # Remove unused private methods
dotnet_diagnostic.S1172.severity = warning # Remove unused method parameters
dotnet_diagnostic.S1186.severity = warning # Methods should not be empty
dotnet_diagnostic.S1192.severity = warning # String literals should not be duplicated
dotnet_diagnostic.S1213.severity = suggestion # Order members in a logical sequence
dotnet_diagnostic.S1694.severity = suggestion # Use meaningful names for variables and methods
dotnet_diagnostic.S1854.severity = warning # Remove dead stores (assignments that are never used)
dotnet_diagnostic.S2328.severity = suggestion # Avoid unnecessary casts
dotnet_diagnostic.S3240.severity = suggestion # Avoid redundant type arguments
dotnet_diagnostic.S3453.severity = suggestion # Use properties instead of fields
dotnet_diagnostic.S3776.severity = warning # Methods should not have high cyclomatic complexity

# Bugs (Reliability)
dotnet_diagnostic.S112.severity = warning  # Avoid throwing generic exceptions
dotnet_diagnostic.S2259.severity = error   # Null pointers should not be dereferenced
dotnet_diagnostic.S2583.severity = error   # Conditions should not unconditionally evaluate to "true" or "false"
dotnet_diagnostic.S2589.severity = error   # Boolean expressions should not be gratuitous
dotnet_diagnostic.S2699.severity = warning # Add assertions to unit tests
dotnet_diagnostic.S2930.severity = error   # "IDisposables" should be properly disposed
dotnet_diagnostic.S2931.severity = error   # "IDisposables" should be properly initialized
dotnet_diagnostic.S3242.severity = suggestion # Use generic methods where possible

# Security Hotspots
dotnet_diagnostic.S2077.severity = error   # Avoid SQL injection
dotnet_diagnostic.S2083.severity = error   # Avoid path traversal vulnerabilities
dotnet_diagnostic.S2095.severity = error   # Properly close resources
dotnet_diagnostic.S3649.severity = error   # Validate inputs before using them in SQL queries

# Code Style
dotnet_diagnostic.S1128.severity = suggestion # Remove unused "using" directives
dotnet_diagnostic.S1214.severity = suggestion # Static members should be accessed statically
dotnet_diagnostic.S1698.severity = suggestion # Avoid using "var" when the type is not obvious
dotnet_diagnostic.S1699.severity = suggestion # Avoid using "var" for built-in types
dotnet_diagnostic.S1697.severity = suggestion # Use "var" when the type is obvious

# Testability
dotnet_diagnostic.S2187.severity = warning # Test cases should contain assertions

# Concurrency
dotnet_diagnostic.S3358.severity = warning # Avoid using Thread.Sleep in tests

# CS1591: Missing XML comment for publicly visible type or member
dotnet_diagnostic.CS1591.severity = none

# Agoda Rules
# AG0019: Do not use System.Runtime.CompilerServices.InternalsVisibleTo attribute
dotnet_diagnostic.AG0019.severity = warning
