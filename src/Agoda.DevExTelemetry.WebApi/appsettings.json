{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=devex-telemetry.db"
  },
  "DataRetention": {
    "RetentionDays": 90,
    "CleanupIntervalHours": 24,
    "VacuumIntervalDays": 7,
    "EnableRawPayloadStorage": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
